    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.dkelectronic.admin",
    "productName": "DK Electronic Admin",
    "win": {
      "target": "portable"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ]
  }
