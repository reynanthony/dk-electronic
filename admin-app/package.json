{
  "name": "dk-electronic-admin",
  "version": "1.0.0",
  "description": "Aplicación de administración para DK Electronic",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "author": "DK Electronic",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
